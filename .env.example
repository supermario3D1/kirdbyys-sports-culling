# Kirdbyys Environment Configuration
# Copy this file to .env and adjust values as needed

# Server
HOST=127.0.0.1
PORT=7840

# Processing
MAX_WORKERS=12
BATCH_SIZE=8
GPU_ENABLED=true
CPU_FALLBACK=true

# Hardware provider toggles
ENABLE_CUDA=true
ENABLE_TENSORRT=false
ENABLE_ROCM=true
ENABLE_OPENVINO=true
ENABLE_DIRECTML=true
ENABLE_COREML=true
ENABLE_MIGRAPHX=false
ENABLE_VITISAI=false
ENABLE_OPENCL=true

IMAGE_RESIZE_LONG_EDGE=1280
